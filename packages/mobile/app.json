{
  "expo": {
    "name": "Family Ice",
    "slug": "family-ice",
    "owner": "familyicedemo",
    "scheme": "familyice",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Family Ice uses your location to alert you when the ice cream van is approaching your street.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Family Ice uses your location in the background to alert you when the van is nearby.",
        "UIBackgroundModes": [
          "location",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.familyicedemo.familyice",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCIbWUKqmeOraNWptvXuvKwWvVrl8eoSJE"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-location",
      "expo-notifications"
    ],
    "extra": {
      "apiBaseUrl": "https://familyice.trafty.com",
      "wsUrl": "wss://familyice.trafty.com/ws",
      "eas": {
        "projectId": "634644e3-afd7-4276-a236-3e0d03a81f25"
      }
    }
  }
}
