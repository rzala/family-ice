{
  "expo": {
    "name": "Family Ice",
    "slug": "family-ice",
    "scheme": "familyice",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Family Ice uses your location to alert you when the ice cream van is approaching your street.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Family Ice uses your location in the background to alert you when the van is nearby.",
        "UIBackgroundModes": ["location", "remote-notification"]
      }
    },
    "android": {
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "plugins": [
      "expo-location",
      "expo-notifications"
    ],
    "extra": {
      "apiBaseUrl": "https://familyice.prod.trafty.com",
      "wsUrl": "wss://familyice.prod.trafty.com/ws"
    }
  }
}
