{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "E2E Gate Configuration",
  "description": "Configuration for the SpecKit E2E gating framework. Generated by /speckit.e2e.init.",
  "type": "object",
  "required": ["stack", "auth", "urls"],
  "properties": {
    "stack": {
      "type": "object",
      "description": "Detected or user-specified tech stack",
      "properties": {
        "frontend": {
          "type": "string",
          "enum": ["react", "vue", "svelte", "angular", "next", "nuxt", "sveltekit", "astro", "solid", "other", ""],
          "description": "Frontend framework"
        },
        "bundler": {
          "type": "string",
          "enum": ["vite", "webpack", "esbuild", "turbopack", "parcel", "other", ""],
          "description": "Build tool / bundler"
        },
        "backend": {
          "type": "string",
          "enum": ["go-fiber", "go-gin", "go-echo", "express", "fastify", "nestjs", "django", "flask", "fastapi", "rails", "laravel", "spring", "other", ""],
          "description": "Backend framework"
        },
        "styling": {
          "type": "string",
          "enum": ["tailwindcss", "css-modules", "styled-components", "emotion", "sass", "vanilla", "other", ""],
          "description": "CSS/styling approach"
        }
      }
    },
    "auth": {
      "type": "object",
      "description": "Authentication configuration for test bypass",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["jwt-localstorage", "jwt-cookie", "session-cookie", "oauth-mock", "none"],
          "description": "How auth tokens are stored and transmitted"
        },
        "tokenKey": {
          "type": "string",
          "description": "localStorage key or cookie name for the token"
        },
        "headerFormat": {
          "type": "string",
          "description": "Authorization header format. Use {token} as placeholder."
        },
        "testLoginEndpoint": {
          "type": "string",
          "description": "Backend endpoint that mints test JWTs (must be guarded by APP_ENV=test)"
        }
      }
    },
    "urls": {
      "type": "object",
      "description": "URLs for the application under test",
      "properties": {
        "baseURL": {
          "type": "string",
          "description": "Frontend base URL (Playwright navigates here)"
        },
        "apiURL": {
          "type": "string",
          "description": "Backend API URL (for test login endpoint)"
        },
        "protectedRoute": {
          "type": "string",
          "description": "A route that requires authentication (used by gate-auth test)"
        }
      }
    },
    "selectors": {
      "type": "object",
      "properties": {
        "convention": {
          "type": "string",
          "enum": ["data-testid", "data-test", "data-cy", "data-qa"],
          "description": "Attribute convention for test selectors"
        }
      }
    },
    "seed": {
      "type": "object",
      "properties": {
        "command": {
          "type": "string",
          "description": "Shell command to seed the backend before tests (optional)"
        }
      }
    },
    "email": {
      "type": "object",
      "description": "Email verification via IMAP (for signup/activation flows)",
      "properties": {
        "imap": {
          "type": "object",
          "properties": {
            "host": {
              "type": "string",
              "description": "IMAP server hostname",
              "default": "imap.gmail.com"
            },
            "port": {
              "type": "integer",
              "description": "IMAP server port",
              "default": 993
            },
            "tls": {
              "type": "boolean",
              "description": "Use TLS for IMAP connection",
              "default": true
            }
          }
        },
        "auth": {
          "type": "object",
          "properties": {
            "user": {
              "type": "string",
              "description": "IMAP username (email address)"
            },
            "appPasswordFile": {
              "type": "string",
              "description": "Path to file containing the app password (supports ~ expansion)",
              "default": "~/.config/himalaya/.gmail-app-pw"
            }
          }
        },
        "pollIntervalMs": {
          "type": "integer",
          "description": "How often to poll for new emails (ms)",
          "default": 2000
        },
        "timeoutMs": {
          "type": "integer",
          "description": "Max time to wait for an email (ms)",
          "default": 60000
        }
      }
    },
    "polling": {
      "type": "object",
      "description": "Default polling settings for async backend operations",
      "properties": {
        "defaultIntervalMs": {
          "type": "integer",
          "description": "Default polling interval (ms)",
          "default": 500
        },
        "defaultTimeoutMs": {
          "type": "integer",
          "description": "Default polling timeout (ms)",
          "default": 30000
        }
      }
    },
    "environment": {
      "type": "object",
      "description": "Test environment lifecycle — ephemeral docker-compose stacks for non-idempotent tests",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["local", "ephemeral", "hybrid"],
          "default": "local",
          "description": "local = connect to running app; ephemeral = spin up compose stack per run; hybrid = gates use local, journeys use ephemeral"
        },
        "compose": {
          "type": "object",
          "description": "Docker Compose settings (used when mode is ephemeral or hybrid)",
          "properties": {
            "file": {
              "type": "string",
              "description": "Path to docker-compose file relative to e2e/ directory",
              "default": "docker-compose.e2e.yml"
            },
            "projectPrefix": {
              "type": "string",
              "description": "Compose project name prefix (a random suffix is appended per run)",
              "default": "e2e"
            },
            "portOffset": {
              "type": "integer",
              "description": "Added to default ports to avoid clashing with dev stack (e.g. 100 → app on 3100 instead of 3000)",
              "default": 100
            },
            "upTimeoutSec": {
              "type": "integer",
              "description": "Max seconds to wait for compose services to become healthy",
              "default": 60
            }
          }
        },
        "services": {
          "type": "object",
          "description": "Service healthcheck definitions",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "healthcheck": {
                "type": "string",
                "description": "URL to poll for 200 OK (use {port} placeholder for offset port)"
              },
              "readyTimeoutMs": {
                "type": "integer",
                "description": "Max ms to wait for this service to become healthy",
                "default": 30000
              }
            }
          }
        },
        "seed": {
          "type": "object",
          "description": "Database seeding for ephemeral environments",
          "properties": {
            "command": {
              "type": "string",
              "description": "Shell command to seed the database (use {project} for compose project name)"
            },
            "runBefore": {
              "type": "string",
              "enum": ["suite", "each", "reset"],
              "default": "suite",
              "description": "suite = once before all tests; each = before each test file; reset = truncate + reseed between tests"
            }
          }
        },
        "teardown": {
          "type": "string",
          "enum": ["always", "on-pass", "never"],
          "default": "always",
          "description": "When to tear down the compose stack (always = even on failure, on-pass = keep on failure for debugging, never = leave running)"
        }
      }
    }
  }
}
